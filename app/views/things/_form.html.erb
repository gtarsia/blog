<%= form_with(model: thing, local: true) do |form| %>
  <% if thing.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(thing.errors.count, "error") %> prohibited this thing from being saved:</h2>

      <ul>
      <% thing.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :title %>
    <%= form.text_field :title, id: :thing_title, class: 'title edit',
      autofocus: true %>
  </div>

  <div class="field">
    <%= form.label :text %>
    <%= form.text_area :text, id: :thing_text, class: 'text edit' %>
  </div>

  <div class="actions">
    <%= form.submit %>
  </div>
<% end %>
