wind = null
steps = 2
duration = 15000
windify = ->
  wind = document.getElementById('wind')
  Object.defineProperty wind, 'alpha',
    get: ->
      HTMLElement::alpha = (a) ->
      current_color = getComputedStyle(this).getPropertyValue('color')
      match = /rgba?\((\d+)\s*,\s*(\d+)\s*,\s*(\d+)\s*(?:,\s*(\d+[\.\d+]*))?\)/g.exec(current_color)
      return match[4] ? "1"
    set: (alpha) ->
      @style.color = "rgba(0,0,0,#{alpha})"

  wind.addEventListener 'keyup', ->
    wind.alpha = 1
    opacityInterval()
  opacityInterval()

interval = null
opacityInterval = ->
  step = duration / steps
  if interval?
    clearInterval interval
  interval = setInterval lowerOpacity, step

lowerOpacity = ->
  wind.alpha -= 1 / steps
  if wind.alpha <= 0
    wind.value = ''
    clearInterval interval


