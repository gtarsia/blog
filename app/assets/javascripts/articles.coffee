document.addEventListener "turbolinks:load", ->
  bindTitle = ->
    changeTitle = ->
      title = document.getElementById('article_title').value
      document.title = title
    input = document.getElementById('article_title')
    input.addEventListener 'change', changeTitle
    input.addEventListener 'keyup', changeTitle


  if document.body.classList.contains 'articles', 'new' or
     document.body.classList.contains 'articles', 'edit'
    bindTitle()
    windify()


